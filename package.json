{
  "name": "ws-screenshot",
  "version": "1.3.0",
  "description": "Fast websocket + rest api based screenshot server, with optional Electron desktop app",
  "main": "electron/main.js",
  "scripts": {
    "server": "node index.js -p 3000 --oc 1",
    "start": "electron .",
    "build": "electron-builder --mac --linux",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "bin": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamjairo/screenshot-app.git"
  },
  "author": "iamjairo",
  "bugs": {
    "url": "https://github.com/iamjairo/screenshot-app/issues"
  },
  "homepage": "https://github.com/iamjairo/screenshot-app#readme",
  "dependencies": {
    "@elestio/cloudgate": "^1.0.125",
    "puppeteer": "^24.0.0"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "io.github.iamjairo.screenshot-app",
    "productName": "Screenshot App",
    "files": [
      "electron/**/*",
      "API/**/*",
      "public/**/*",
      "appconfig.json",
      "index.js",
      "package.json",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ]
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "category": "Development"
    }
  }
}
